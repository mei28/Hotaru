    },
    "Enable Hotaru" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hotaru を有効にする"
          }
        }
      }
    },
    "Hotaru needs Accessibility permission to detect the active window.\nOpen System Settings, enable Hotaru in the list, then quit and restart Hotaru." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hotaru はアクティブウィンドウを検出するためにアクセシビリティ権限を必要とします。\n「システム設定を開く」を押し、リスト内の Hotaru をオンにしたあと、Hotaru を一度終了して再起動してください。"
          }
        }
      }
    },
    "Hotaru Settings" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hotaru の設定"
          }
        }
